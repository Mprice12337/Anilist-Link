# Anilist-Link Local Development Environment
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Values set here override code defaults but are overridden by
# settings saved in the web UI (stored in ./data/anilist_link.db).
# Priority: env var > DB setting > code default

# --- General ---
DEBUG=true
TZ=America/New_York

# --- AniList OAuth2 ---
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# --- Crunchyroll ---
CRUNCHYROLL_EMAIL=
CRUNCHYROLL_PASSWORD=
FLARESOLVERR_URL=
HEADLESS_MODE=true
MAX_PAGES=10

# --- Plex ---
PLEX_URL=
PLEX_TOKEN=
PLEX_ANIME_LIBRARIES=[]

# --- Jellyfin ---
JELLYFIN_URL=
JELLYFIN_API_KEY=

# --- Scheduler ---
SCAN_INTERVAL=24
SYNC_INTERVAL=15
